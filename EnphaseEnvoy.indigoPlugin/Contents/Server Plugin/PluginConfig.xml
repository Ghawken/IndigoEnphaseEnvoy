<?xml version="1.0"?>
<PluginConfig>
  <Field id="infoLabel0" type="label" fontSize='large' fontColor="black">
    <Label>Enphase Envoy Plugin</Label>
  </Field>

  <Field id="space0" type="label" fontColor="black" >
    <Label>Developed by: GlennNZ</Label>
  </Field>
  <Field id="sep7" type="separator"/>

  <Field id="space1" type="label" fontColor="black">
    <Label>Check for Updates:</Label>
  </Field>
  <Field id="sep6" type="separator"/>
  <Field id="space2" type="label" fontSize="small" fontColor="black">
    <Label>The amount of time that the plugin will wait between checking for updated version</Label>
  </Field>

  <Field id="configUpdaterInterval" type="textfield" defaultValue="24" tooltip="Select preference for how often updates will be checked">
    <Label>Update Check Interval:(hours)</Label>
  </Field>

    <Field id="openStore" type="checkbox" tooltip="Will automatic install newer version at check.">
    <Label> Open PluginStore if newer version at time of check</Label>
    <Description>Enable/Disable</Description>
  </Field>

 <Field id="sep9" type="separator"/>

  <Field id="space10" type="label" alignText="left">
    <Label>Debugging:</Label>
  </Field>

  <Field id="sep4" type="separator"/>

  <Field id="space11" type="label" fontSize="small">
    <Label>Turn on debugging only when needed. Be careful when posting the output to the forums or other public places as it could expose sensitive information.</Label>
  </Field>

  <Field id="showDebugInfo" type="checkbox" tooltip="Enabling will result in verbose logging.">
    <Label> </Label>
    <Description>Enable/Disable</Description>
  </Field>
    <Field id="debugupdate" type="checkbox" tooltip="Enabling will result Debugging Update.">
        <Label/>
        <Description>Debug Plugin Updating</Description>
    </Field>
    <Field id="showDebugLevel" type="menu" defaultValue="20">
        <Label>Indigo Log Debug level:</Label>
        <Description>Level of debug information in Indigo Event Log.</Description>
        <List>
            <Option value="5">Detailed Debugging Messages</Option>
            <Option value="10">Debugging Messages</Option>
            <Option value="20">Informational Messages</Option>
            <Option value="30">Warning Messages</Option>
            <Option value="40">Error Messages</Option>
            <Option value="50">Critical Errors Only</Option>
        </List>
    </Field>

    <Field id="showDebugFileLevel" type="menu" defaultValue="5">
        <Label>File Debug level:</Label>
        <Description>Level of debug information saved to plugin log file.</Description>
        <List>
            <Option value="5">Detailed Debugging Messages</Option>
            <Option value="10">Debugging Messages</Option>
            <Option value="20">Informational Messages</Option>
            <Option value="30">Warning Messages</Option>
            <Option value="40">Error Messages</Option>
            <Option value="50">Critical Errors Only</Option>
        </List>
    </Field>

  <Field id="sep10" type="separator"/>
  <Field id="tokenLabel" type="label" fontColor="black">
    <Label>Token Management:</Label>
  </Field>
  <Field id="forceTokenClear" type="checkbox" defaultValue="false" tooltip="Check this to clear all saved generated tokens on next plugin startup. The setting resets automatically after tokens are cleared.">
    <Label> </Label>
    <Description>Force clear all generated tokens on next startup</Description>
  </Field>

</PluginConfig>
