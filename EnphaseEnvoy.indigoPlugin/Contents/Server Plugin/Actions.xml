<?xml version="1.0"?>
<Actions>
  <Action id="refreshData">
    <Name>Refresh data for all devices...</Name>
    <CallbackMethod>refreshDataAction</CallbackMethod>
  </Action>

  <Action id="refreshDataForDev" deviceFilter="self">
    <Name>Refresh data for device...</Name>
    <CallbackMethod>refreshDataForDevAction</CallbackMethod>
  </Action>

<Action id="enablePowerProduction" deviceFilter="self.EnphaseEnvoyDevice">
    <Name>Enable Power Production</Name>
    <CallbackMethod>enablePowerProduction</CallbackMethod>
</Action>

<Action id="disablePowerProduction" deviceFilter="self.EnphaseEnvoyDevice">
    <Name>Disable Power Production</Name>
    <CallbackMethod>disablePowerProduction</CallbackMethod>
</Action>
<Action id="setStorageModeSelfConsumption" deviceFilter="self.EnphaseEnvoyBatteryDevice">
    <Name>Set Storage Mode: Self-Consumption</Name>
    <CallbackMethod>setStorageModeSelfConsumptionAction</CallbackMethod>
</Action>

<Action id="setStorageModeSavings" deviceFilter="self.EnphaseEnvoyBatteryDevice">
    <Name>Set Storage Mode: Savings</Name>
    <CallbackMethod>setStorageModeSavingsAction</CallbackMethod>
</Action>

<Action id="setStorageModeFullBackup" deviceFilter="self.EnphaseEnvoyBatteryDevice">
    <Name>Set Storage Mode: Full Backup</Name>
    <CallbackMethod>setStorageModeFullBackupAction</CallbackMethod>
</Action>

<Action id="enableChargeFromGrid" deviceFilter="self.EnphaseEnvoyBatteryDevice">
    <Name>Enable Charge from Grid</Name>
    <CallbackMethod>enableChargeFromGridAction</CallbackMethod>
</Action>

<Action id="disableChargeFromGrid" deviceFilter="self.EnphaseEnvoyBatteryDevice">
    <Name>Disable Charge from Grid</Name>
    <CallbackMethod>disableChargeFromGridAction</CallbackMethod>
</Action>

<Action id="setReserveSOC" deviceFilter="self.EnphaseEnvoyBatteryDevice">
    <Name>Set Battery Reserve Percentage</Name>
    <CallbackMethod>setReserveSOCAction</CallbackMethod>
    <ConfigUI>
      <Field id="reservePercent" type="textfield" defaultValue="20">
        <Label>Reserve SOC (0-100%):</Label>
      </Field>
    </ConfigUI>
</Action>

<Action id="refreshBatteryData" deviceFilter="self.EnphaseEnvoyBatteryDevice">
    <Name>Refresh Battery &amp; Grid Data</Name>
    <CallbackMethod>refreshBatteryDataAction</CallbackMethod>
</Action>

<Action id="enableDpel" deviceFilter="self.EnphaseEnvoyDevice">
    <Name>Enable DPEL (Export Limiting)</Name>
    <CallbackMethod>enableDpelAction</CallbackMethod>
    <ConfigUI>
      <Field id="dpelInfoLabel" type="label" fontSize="small">
        <Label>DPEL (Dynamic Power Export Limiting) controls how much power your solar system exports to the grid. This requires an installer-level token. The Envoy enforces the limit by curtailing inverter output in real time.</Label>
      </Field>
      <Field id="dpelSep1" type="separator"/>
      <Field id="dpelWatts" type="textfield" defaultValue="0">
        <Label>Export Limit (Watts):</Label>
        <Description>Maximum watts allowed to be exported (or produced). Set to 0 for zero export.</Description>
      </Field>
      <Field id="dpelSlewRate" type="textfield" defaultValue="50">
        <Label>Slew Rate:</Label>
        <Description>How quickly (watts/sec) the Envoy ramps inverter output up or down to meet the limit. Lower values produce smoother, slower adjustments.</Description>
      </Field>
      <Field id="dpelSep2" type="separator"/>
      <Field id="dpelExportLimit" type="checkbox" defaultValue="true">
        <Label>Export Limit Mode:</Label>
        <Description>Checked = limit grid export only (excess powers your home first). Unchecked = limit total production.</Description>
      </Field>
    </ConfigUI>
</Action>

<Action id="disableDpel" deviceFilter="self.EnphaseEnvoyDevice">
    <Name>Disable DPEL (Export Limiting)</Name>
    <CallbackMethod>disableDpelAction</CallbackMethod>
    <ConfigUI>
      <Field id="dpelDisableLabel" type="label" fontSize="small">
        <Label>This will disable DPEL (Dynamic Power Export Limiting) and allow unrestricted power export to the grid. Requires an installer-level token.</Label>
      </Field>
    </ConfigUI>
</Action>
</Actions>

